# =============================================================================
# Hermes Agent Environment Variables Template
# =============================================================================
# Copy to ~/.hermes/.env and fill in your API keys.
# NEVER commit your actual .env file — it contains secrets.
# =============================================================================

# ── Required: Model Provider ─────────────────────────────────────────────
# DeepSeek (recommended for math/research)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Alternatives (uncomment one):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ── Web Search ───────────────────────────────────────────────────────────
# SearXNG URL is set in docker-compose.yml (http://searxng-core:8080)
# Override here only if using an external SearXNG instance

# Optional: commercial search APIs for web_extract
# FIRECRAWL_API_KEY=fc-...
# TAVILY_API_KEY=tvly-...
# EXA_API_KEY=...

# ── Voice (optional) ─────────────────────────────────────────────────────
# Local STT works out of the box (faster-whisper)
# For cloud TTS/STT, uncomment:
# ELEVENLABS_API_KEY=...
# OPENAI_API_KEY=...  (also used for TTS/STT)

# ── Gateway Platforms (optional) ─────────────────────────────────────────
# Uncomment if you want to connect messaging platforms
# TELEGRAM_BOT_TOKEN=...
# QQ_APP_ID=...
# QQ_CLIENT_SECRET=...

# ── Docker-specific ──────────────────────────────────────────────────────
# These are set in docker-compose.yml, not here
# HERMES_HOME=/opt/data
# PYTHONPATH=/opt/data/pip-packages
